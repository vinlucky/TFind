.search-section {
  margin-bottom: 24rpx;
}

.location-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 16rpx 20rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
}

.location-status {
  font-size: 26rpx;
  color: #4A90D9;
}

.location-error {
  color: #e74c3c;
}

.btn-location {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  background: #4A90D9;
  color: #ffffff;
  border: none;
  border-radius: 8rpx;
}

.mode-row {
  margin-bottom: 20rpx;
}

.mode-label {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 12rpx;
  display: block;
}

.mode-group {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.mode-item {
  display: flex;
  align-items: center;
  margin-right: 32rpx;
  margin-bottom: 8rpx;
  font-size: 28rpx;
}

.mode-item radio {
  transform: scale(0.8);
  margin-right: 4rpx;
}

.distance-row {
  margin-bottom: 24rpx;
}

.distance-row slider {
  width: 100%;
}

.find-btn {
  width: 100%;
  margin-top: 16rpx;
}

.toilet-card {
  margin-bottom: 16rpx;
}

.card-header {
  margin-bottom: 12rpx;
}

.toilet-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  flex: 1;
}

.toilet-distance {
  font-size: 28rpx;
  color: #4A90D9;
  font-weight: 500;
}

.card-info {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.info-item {
  font-size: 24rpx;
  color: #888888;
  margin-right: 20rpx;
  margin-bottom: 4rpx;
}

.score-item {
  color: #f5a623;
}

.ai-score-item {
  color: #7b68ee;
  font-weight: 500;
}

.card-tags {
  margin-bottom: 8rpx;
}

.card-address {
  font-size: 24rpx;
  color: #999999;
}

.loading-text {
  color: #999999;
  font-size: 28rpx;
}

.recommend-entry {
  margin-top: 20rpx;
}

.recommend-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 24rpx;
}

.recommend-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #4A90D9;
  margin-bottom: 12rpx;
}

.recommend-desc {
  font-size: 26rpx;
  color: #999999;
}
