page {
  background-color: #f5f5f5;
}

.container {
  padding: 20rpx;
}

.form-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-top: 20rpx;
}

.form-group {
  margin-bottom: 40rpx;
}

.form-group .label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-group .input {
  width: 100%;
  height: 80rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.btn-area {
  margin-top: 60rpx;
}
