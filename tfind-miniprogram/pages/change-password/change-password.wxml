<view class="container">
  <view class="form-section">
    <view class="form-group">
      <text class="label">原密码</text>
      <input class="input" type="password" placeholder="请输入原密码" bindinput="onOldPasswordInput" />
    </view>

    <view class="form-group">
      <text class="label">新密码</text>
      <input class="input" type="password" placeholder="请输入新密码（至少6位）" bindinput="onNewPasswordInput" />
    </view>

    <view class="form-group">
      <text class="label">确认新密码</text>
      <input class="input" type="password" placeholder="请再次输入新密码" bindinput="onConfirmPasswordInput" />
    </view>

    <view class="btn-area">
      <button class="btn-primary" bindtap="submitChange">确认修改</button>
    </view>
  </view>
</view>
