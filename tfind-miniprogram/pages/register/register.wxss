.register-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  box-sizing: border-box;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.logo {
  width: 140rpx;
  height: 140rpx;
  margin-bottom: 24rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.app-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.form-area {
  width: 100%;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.input-group {
  margin-bottom: 24rpx;
}

.input-group .input-field {
  background-color: #f5f7fa;
  border-radius: 12rpx;
  height: 96rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  color: #333333;
  margin-bottom: 0;
}

.input-hint {
  font-size: 22rpx;
  color: #999999;
  margin-top: 8rpx;
  padding-left: 8rpx;
}

.placeholder-text {
  color: #c0c4cc;
}

.register-btn {
  margin-top: 36rpx;
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 34rpx;
}

.login-link {
  text-align: center;
  margin-top: 32rpx;
}

.link-text {
  color: #4A90D9;
  font-size: 28rpx;
}
