.map-container {
  width: 100%;
  height: 100vh;
  position: relative;
}

.toilet-map {
  width: 100%;
  height: 100vh;
}

.map-controls {
  position: absolute;
  right: 24rpx;
  bottom: 200rpx;
  z-index: 10;
}

.control-btn {
  width: 80rpx;
  height: 80rpx;
  background-color: #ffffff;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
  margin-bottom: 16rpx;
}

.control-icon {
  font-size: 40rpx;
  color: #4A90D9;
}

.bottom-list {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 24rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.1);
  z-index: 10;
}

.list-card {
  padding: 16rpx 0;
}

.list-header {
  margin-bottom: 8rpx;
}

.list-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.list-go {
  font-size: 28rpx;
  color: #4A90D9;
}

.list-info {
  font-size: 26rpx;
  color: #888888;
  margin-bottom: 8rpx;
}

.list-tags {
  margin-bottom: 4rpx;
}

.close-btn {
  text-align: center;
  padding: 16rpx 0;
  color: #999999;
  font-size: 26rpx;
}
