.detail-header {
  padding: 28rpx 24rpx;
}

.toilet-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  flex: 1;
}

.toilet-distance {
  font-size: 28rpx;
  color: #4A90D9;
  font-weight: 500;
}

.score-row {
  display: flex;
  margin-top: 16rpx;
  margin-bottom: 12rpx;
}

.score-item {
  font-size: 28rpx;
  color: #f5a623;
  margin-right: 24rpx;
}

.ai-score {
  font-size: 28rpx;
  color: #7b68ee;
  font-weight: 500;
}

.reviewer-row {
  margin-top: 8rpx;
}

.reviewer-text {
  font-size: 22rpx;
  color: #4A90D9;
  background-color: #e8f4fd;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.info-row {
  font-size: 26rpx;
  color: #888888;
  margin-bottom: 12rpx;
}

.tags-row {
  margin-bottom: 12rpx;
}

.ai-tag {
  background-color: #ede7f6 !important;
  color: #7b68ee !important;
}

.address-row {
  margin-bottom: 12rpx;
}

.address-text {
  font-size: 26rpx;
  color: #666666;
}

.facility-row {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.facility-tag {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  background-color: #e3f2fd;
  color: #1976d2;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.facility-tag.queuing {
  background-color: #fff3e0;
  color: #e65100;
}

.photo-row {
  margin-bottom: 12rpx;
}

.toilet-photo {
  width: 100%;
  border-radius: 12rpx;
}

.ai-analysis {
  background-color: #f3e5f5;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
}

.ai-label {
  font-size: 24rpx;
  color: #7b68ee;
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
}

.ai-content {
  font-size: 26rpx;
  color: #555555;
  line-height: 1.6;
}

.action-row {
  margin-top: 16rpx;
}

.nav-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
}

.action-buttons {
  padding: 16rpx 24rpx;
}

.btn-group {
  display: flex;
  justify-content: space-around;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 24rpx;
}

.action-icon {
  font-size: 44rpx;
  margin-bottom: 4rpx;
}

.action-text {
  font-size: 24rpx;
  color: #666666;
}

.form-group {
  margin-bottom: 20rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 8rpx;
  display: block;
}

.tags-area {
  display: flex;
  flex-wrap: wrap;
}

.switch-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 28rpx;
}

.picker-field {
  background-color: #f5f7fa;
  border-radius: 12rpx;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  margin-bottom: 20rpx;
}

.placeholder-text {
  color: #c0c4cc;
}

.reviews-section {
  padding: 24rpx;
}

.review-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.review-item:last-child {
  border-bottom: none;
}

.review-header {
  margin-bottom: 8rpx;
}

.review-user {
  display: flex;
  align-items: center;
}

.review-username {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-right: 12rpx;
}

.review-score {
  font-size: 24rpx;
  color: #f5a623;
}

.review-actions {
  display: flex;
}

.delete-btn {
  font-size: 24rpx;
  color: #e74c3c;
  padding: 4rpx 16rpx;
}

.review-content {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
  margin-bottom: 8rpx;
  display: block;
}

.review-tags {
  margin-bottom: 8rpx;
}

.review-time {
  font-size: 22rpx;
  color: #cccccc;
  display: block;
}

.updates-section {
  padding: 24rpx;
}

.update-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.update-item:last-child {
  border-bottom: none;
}

.update-header {
  margin-bottom: 8rpx;
}

.update-user {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-right: 12rpx;
}

.update-score {
  font-size: 24rpx;
  color: #f5a623;
}

.update-tags {
  margin-bottom: 8rpx;
}

.update-content {
  font-size: 26rpx;
  color: #555555;
  line-height: 1.5;
  display: block;
  margin-bottom: 8rpx;
}

.update-time {
  font-size: 22rpx;
  color: #cccccc;
  display: block;
}
